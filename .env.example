# Application mode.
# APP_MODE=live also requires LIVE_ENABLED=true in order to pass the safety gate.
APP_MODE=paper
LIVE_ENABLED=false

# Dashboard port used by start_multi_chain.py.
PORT=8050

# Chain selection.
APP_CHAIN=bsc
APP_CHAINS=bsc,sol,eth
APP_NAME=trading-system

# Optional notification credentials.
# Do not commit real token values.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional 6551 / Twitter integration token.
TWITTER_TOKEN=
